<UserControl x:Class="UOAIO.Launcher.Scenes.LicenseGateSceneControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="640"
             MinHeight="420">
    <Grid Background="Transparent">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="560" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="1"
                MaxWidth="560"
                Padding="32"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Style="{StaticResource SceneCardBorderStyle}">
            <StackPanel>
                <TextBlock Style="{StaticResource EyebrowTextBlockStyle}"
                           Text="LICENSED ENTRY" />
                <TextBlock Margin="0,10,0,0"
                           Style="{StaticResource HeroTitleTextBlockStyle}"
                           Text="UO-AIO Launcher" />
                <TextBlock Margin="0,14,0,0"
                           Style="{StaticResource MutedBodyTextBlockStyle}"
                           TextWrapping="Wrap"
                           Text="Validate the launcher license before entering the shard workflows." />

                <Border Margin="0,28,0,0"
                        Padding="22"
                        Style="{StaticResource InsetPanelBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}"
                                   Text="License Gate" />
                        <StackPanel x:Name="LicenseEntryPanel"
                                    Margin="0,18,0,0">
                            <TextBlock Style="{StaticResource FieldLabelTextBlockStyle}"
                                       Text="License Key" />
                            <TextBox x:Name="LicenseKeyTextBox"
                                     Margin="0,6,0,0" />

                            <StackPanel x:Name="DeveloperOverridePanel"
                                        Margin="0,14,0,0"
                                        Visibility="Collapsed">
                                <TextBlock Style="{StaticResource FieldLabelTextBlockStyle}"
                                           Text="Debug License Server Override" />
                                <TextBox x:Name="ServerOverrideTextBox"
                                         Margin="0,6,0,0" />
                            </StackPanel>

                            <Button x:Name="ValidateButton"
                                    Margin="0,20,0,0"
                                    Click="ValidateButton_Click"
                                    Content="Validate And Enter"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                        </StackPanel>

                        <TextBlock x:Name="StatusTextBlock"
                                   Margin="0,14,0,0"
                                   Style="{StaticResource StatusTextBlockStyle}"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="EndpointTextBlock"
                                   Margin="0,12,0,0"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
