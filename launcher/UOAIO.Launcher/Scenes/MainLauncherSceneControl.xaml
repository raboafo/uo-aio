<UserControl x:Class="UOAIO.Launcher.Scenes.MainLauncherSceneControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8"
          Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="18"
                Style="{StaticResource InsetPanelBorderStyle}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}"
                           Text="Launcher Access Granted" />
                <TextBlock x:Name="LicenseBannerTextBlock"
                           Margin="0,10,0,0"
                           Style="{StaticResource MutedBodyTextBlockStyle}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,22,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" />
                <ColumnDefinition Width="22" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Border Padding="24"
                        Style="{StaticResource SceneCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource EyebrowTextBlockStyle}"
                                   Text="NAVIGATION" />
                        <TextBlock Margin="0,10,0,0"
                                   Style="{StaticResource HeroTitleTextBlockStyle}"
                                   Text="Shard Selection" />
                        <TextBlock Margin="0,14,0,22"
                                   Style="{StaticResource MutedBodyTextBlockStyle}"
                                   TextWrapping="Wrap"
                                   Text="Choose a shard and let its workflow prepare runtime state for the client." />

                        <Border Padding="18"
                                Style="{StaticResource InsetPanelBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}"
                                           Text="Shards" />
                                <TextBlock Margin="0,12,0,10"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Text="Select the shard whose runtime behavior should become active." />
                                <ListBox x:Name="ShardListBox"
                                         MinHeight="260"
                                         DisplayMemberPath="Name"
                                         SelectionChanged="ShardListBox_SelectionChanged" />
                                <CheckBox x:Name="RememberInputsCheckBox"
                                          Margin="0,14,0,0"
                                          Content="Remember shard credentials and input values on this machine" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <Border Grid.Column="2"
                    Padding="26"
                    Style="{StaticResource SceneCardBorderStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Style="{StaticResource EyebrowTextBlockStyle}"
                                   Text="WORKFLOW SURFACE" />
                        <TextBlock Margin="0,10,0,0"
                                   Style="{StaticResource HeroTitleTextBlockStyle}"
                                   Text="Active Shard Preparation" />
                        <TextBlock Margin="0,14,0,0"
                                   Style="{StaticResource MutedBodyTextBlockStyle}"
                                   TextWrapping="Wrap"
                                   Text="Each shard owns its own preparation flow and writes a slim runtime state for the client to consume later." />

                        <Border Margin="0,24,0,18"
                                Padding="18"
                                Style="{StaticResource InsetPanelBorderStyle}">
                            <StackPanel>
                                <TextBlock x:Name="SelectedShardNameTextBlock"
                                           Style="{StaticResource SectionTitleTextBlockStyle}"
                                           Text="No shard selected" />
                                <TextBlock x:Name="SelectedShardDescriptionTextBlock"
                                           Margin="0,10,0,0"
                                           Style="{StaticResource MutedBodyTextBlockStyle}"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="SelectedShardEndpointTextBlock"
                                           Margin="0,10,0,0"
                                           Foreground="{StaticResource AccentBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}"
                                   Text="Shard Workflow" />
                        <TextBlock Margin="0,10,0,0"
                                   Style="{StaticResource MutedBodyTextBlockStyle}"
                                   TextWrapping="Wrap"
                                   Text="The selected shard decides which controls, actions, and transitions it needs in order to prepare runtime state." />
                        <ContentControl x:Name="ShardWorkflowContentControl"
                                        Margin="0,18,0,0" />
                        <TextBlock x:Name="SaveStatusTextBlock"
                                   Margin="0,14,0,0"
                                   Style="{StaticResource StatusTextBlockStyle}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,22,0,4"
                                   Style="{StaticResource FieldLabelTextBlockStyle}"
                                   Text="Bootstrap Transport" />
                        <TextBlock x:Name="ActiveStatePathTextBlock"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   TextWrapping="Wrap" />

                        <GroupBox Margin="0,18,0,0"
                                  Header="Prepared State Preview">
                            <TextBox x:Name="ActiveStatePreviewTextBox"
                                     Height="210"
                                     IsReadOnly="True"
                                     Style="{StaticResource ReadOnlyCodeTextBoxStyle}"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap" />
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
