<Window x:Class="UOAIO.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UO-AIO Launcher"
        Height="820"
        Width="1260"
        MinHeight="680"
        MinWidth="980"
        Background="#0B0908"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="pack://application:,,,/Assets/launcher-bg.png"
                        Stretch="UniformToFill"
                        AlignmentX="Center"
                        AlignmentY="Center" />
        </Grid.Background>

        <Rectangle Fill="{StaticResource WindowBackgroundScrimBrush}" />
        <Rectangle Fill="{StaticResource WindowAtmosphereBrush}" />

        <Grid Margin="24">
            <ContentControl x:Name="SceneHost" />
        </Grid>
    </Grid>
</Window>
